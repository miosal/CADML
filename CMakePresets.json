{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 24 },

  "configurePresets": [
    {
      "name": "default",
      "displayName": "Native (host compiler)",
      "description": "Native libraries + CLI tools + tests. Deps fetched from source via FetchContent (no vcpkg). Per-OS build tree (build/Windows|Linux|Darwin).",
      "binaryDir": "${sourceDir}/build/${hostSystemName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":  "RelWithDebInfo",
        "CADML_BUILD_TESTS": "ON",
        "CADML_BUILD_TOOLS": "ON"
      }
    },
    {
      "name": "minimal",
      "displayName": "Native — libraries + tools only (no tests)",
      "inherits": "default",
      "cacheVariables": { "CADML_BUILD_TESTS": "OFF" }
    },
    {
      "name": "wasm",
      "displayName": "WebAssembly (Emscripten)",
      "description": "Builds cadml.js + cadml.wasm into build/wasm. Needs the Emscripten SDK active (EMSDK set, emcc/ninja on PATH). Deps fetched via FetchContent.",
      "binaryDir": "${sourceDir}/build/wasm",
      "generator": "Ninja",
      "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }
  ],

  "buildPresets": [
    { "name": "default", "configurePreset": "default" },
    { "name": "minimal", "configurePreset": "minimal" },
    { "name": "wasm",    "configurePreset": "wasm" }
  ],

  "testPresets": [
    {
      "name":            "default",
      "configurePreset": "default",
      "output":          { "outputOnFailure": true }
    }
  ]
}
